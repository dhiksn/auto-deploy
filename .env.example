# ── Pilih provider AI: openai | groq | ollama ──────────────────────────────
AI_PROVIDER=groq

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Groq (gratis, cepat) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama (lokal, tidak perlu API key) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Git ──────────────────────────────────────────────────────────────────────
DEFAULT_BRANCH=main
